generator client {
  provider = "prisma-client"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")        
}

model User{
  id          Int      @id default(autoincrement())
  name        String   
  email       String   @unique
  password    String   
  createdAt   DateTime @default(now())
  cars        Car[]
}
model Car{
  id          Int      @id default(autoincrement())
  title       String
  description String
  brand       String
  model       String
  year        Int
  kilometers  Int
  price       Float
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  userId      Int
  user        User     @relation(fields: [userId], references: [id])
}